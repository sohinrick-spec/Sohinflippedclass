          {/* 底部 meta */}
          <div className="mt-2 flex items-center gap-3 text-xs text-gray-400 dark:text-gray-500">
            {lesson.estimatedMin && (
              <span><i className="fas fa-clock mr-1"></i>{lesson.estimatedMin} 分鐘</span>
