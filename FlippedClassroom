/* ============================================================================
 * 【區塊 9】LESSON PLAYER SCREEN（課題播放畫面）
 * ============================================================================ */
function LessonPlayerScreen({ lesson, userName, initialProgress, onSaveProgress, onBack }) {
  const toast = useToast();

  /* ── 狀態 ── */
  const [watchPct, setWatchPct]         = useState(initialProgress?.watchPct || 0);
  const [maxWatchPct, setMaxWatchPct]   = useState(initialProgress?.watchPct || 0);
  const [answers, setAnswers]           = useState(initialProgress?.answers || {});
  const [completedAt, setCompletedAt]   = useState(initialProgress?.completedAt || null);
  const [videoReady, setVideoReady]     = useState(false);
  const [isPlaying, setIsPlaying]       = useState(false);
  const [submitLoading, setSubmitLoading] = useState(false);

  const playerRef    = useRef(null);
  const trackTimer   = useRef(null);
  const containerRef = useRef(null);
  const hasVideo     = lesson.videoId && lesson.videoId !== 'PLACEHOLDER_VIDEO_ID' && lesson.videoId.trim() !== '';
  const questionsUnlocked = maxWatchPct >= CONFIG.VIDEO_UNLOCK_THRESHOLD;
  const totalQ  = lesson.questions?.length || 0;
  const answered = Object.keys(answers).length;
  const allAnswered = totalQ > 0 && answered >= totalQ;

  /* ── YouTube 播放器初始化 ── */
  useEffect(() => {
    if (!hasVideo) return;
    let mounted = true;
    loadYouTubeAPI().then(YT => {
      if (!mounted) return;
      playerRef.current = new YT.Player(containerRef.current, {
        videoId: lesson.videoId,
        playerVars: { rel: 0, modestbranding: 1, cc_load_policy: 0, hl: 'zh-TW' },
        events: {
          onReady:       ()  => { if (mounted) setVideoReady(true); },
          onStateChange: (e) => {
            if (!mounted) return;
            if (e.data === 1) { setIsPlaying(true);  startTracking(YT); }
            else              { setIsPlaying(false); stopTracking(); }
          }
        }
      });
    });
    return () => {
      mounted = false;
      stopTracking();
      if (playerRef.current && playerRef.current.destroy) {
        try { playerRef.current.destroy(); } catch { /* ignore */ }
      }
    };
  }, [lesson.videoId]);

  function startTracking(YT) {
    stopTracking();
    trackTimer.current = setInterval(() => {
      const p = playerRef.current;
      if (!p || typeof p.getCurrentTime !== 'function') return;
      const cur = p.getCurrentTime();
      const dur = p.getDuration();
      if (!dur || dur <= 0) return;
      const pct = Math.round((cur / dur) * 100);
      setWatchPct(pct);
      setMaxWatchPct(prev => {
        const next = Math.max(prev, pct);
        return next;
      });
    }, 2000);
  }

  function stopTracking() {
    if (trackTimer.current) { clearInterval(trackTimer.current); trackTimer.current = null; }
  }

  /* ── 自動儲存進度（每 10 秒或 watchPct 達關鍵節點） ── */
  useEffect(() => {
    const prog = { watchPct: maxWatchPct, answers, completedAt, startedAt: initialProgress?.startedAt || new Date().toISOString() };
    onSaveProgress(lesson.id, prog);
  }, [maxWatchPct, completedAt]); // intentionally limited deps

  /* ── 提交答案 ── */
  async function handleSubmit() {
    if (!allAnswered) { toast('請先回答所有題目', 'warning'); return; }
    setSubmitLoading(true);
    const now = new Date().toISOString();
    const prog = { watchPct: maxWatchPct, answers, completedAt: now, startedAt: initialProgress?.startedAt || now };
    await onSaveProgress(lesson.id, prog);
    setCompletedAt(now);
    setSubmitLoading(false);
    toast('🎉 課題完成！進度已儲存', 'success', 4000);
  }

  /* ── 更新單題答案 ── */
  function setAnswer(qId, val) {
    setAnswers(prev => ({ ...prev, [qId]: val }));
  }

  return (
    <div className="w-full max-w-2xl landscape:max-w-5xl">
      <div className="glass-panel rounded-2xl shadow-xl overflow-hidden">

        {/* ── 頂欄 ── */}
        <div className="flex items-center gap-3 p-4 border-b border-gray-100 dark:border-gray-700 bg-gradient-to-r from-indigo-50 to-purple-50 dark:from-indigo-900/30 dark:to-purple-900/30">
          <button onClick={onBack}
            className="w-9 h-9 rounded-full bg-white dark:bg-gray-700 shadow flex items-center justify-center text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors flex-shrink-0">
            <i className="fas fa-arrow-left"></i>
          </button>
          <div className="flex-1 min-w-0">
            <span className="text-xs text-indigo-500 dark:text-indigo-400 font-bold">{lesson.topic}</span>
            <h2 className="font-bold text-gray-800 dark:text-gray-100 truncate text-sm md:text-base">
              {lesson.title}
            </h2>
          </div>
          {completedAt && (
            <span className="flex-shrink-0 text-xs bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-300 px-2 py-1 rounded-full font-bold">
              <i className="fas fa-check-circle mr-1"></i>已完成
            </span>
          )}
        </div>

        <div className="overflow-y-auto custom-scrollbar max-h-[calc(92vh-64px)] p-4 md:p-6">

          {/* ═══════════════════════════════════════════════
           * 【影片區域】
           * 填入實際課題後，此處將顯示 YouTube 嵌入播放器
           * ═══════════════════════════════════════════════ */}
          <div className="mb-4">
            <div className="relative rounded-xl overflow-hidden shadow-lg bg-black aspect-video">
              {hasVideo ? (
                /* YouTube 播放器容器 */
                <div ref={containerRef} className="w-full h-full" />
              ) : (
                /* 佔位符：尚未填入影片 ID 時顯示 */
                <div className="video-placeholder absolute inset-0 flex flex-col items-center justify-center gap-3">
                  <div className="bg-white dark:bg-gray-800 rounded-xl p-5 shadow-lg text-center max-w-xs border-2 border-dashed border-gray-300 dark:border-gray-600">
                    <i className="fab fa-youtube text-5xl text-red-500 mb-3"></i>
                    <p className="font-bold text-gray-700 dark:text-gray-200 text-sm">影片尚未設定</p>
                    <p className="text-xs text-gray-400 dark:text-gray-500 mt-1">
