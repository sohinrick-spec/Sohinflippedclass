 *   topic       - 所屬主題／章節標籤
 *   description - 課題簡介
 *   videoId     - YouTube 影片 ID（網址中 v= 後的部分）
 *   dueDate     - 截止日期（格式 'YYYY-MM-DD'，可選）
 *   estimatedMin- 預計觀看時間（分鐘）
 *   questions   - 題目陣列（見下方格式說明）
 *
 * 題目格式：
 *   MCQ:  { type:'mcq',  id:'Q1', text:'題目文字', options:['A','B','C','D'], answer: 0 }
 *         （answer 為正確選項的 index，從 0 開始）
 *   填充: { type:'fill', id:'Q2', text:'題目文字', answer:'參考答案' }
 *
 * ============================================================================ */
const LESSONS = [
  /* ────────────────────────────────────────────────────────────
   * TODO: 在此處填入實際課題。範例結構如下，取消注解後填入資料：
   * ────────────────────────────────────────────────────────────
  {
    id: 'L001',
    title: '第一課：細胞的基本結構',
    topic: 'Ch.2 細胞',
    description: '學習原核細胞與真核細胞的主要差異，以及各種胞器的功能。',
    videoId: 'YOUTUBE_VIDEO_ID_HERE',   // ← 填入 YouTube 影片 ID
    dueDate: '2026-06-01',
    estimatedMin: 15,
    questions: [
      // MCQ 範例：
      { type: 'mcq', id: 'Q1', text: '下列哪種胞器負責合成蛋白質？',
        options: ['核糖體', '葉綠體', '粒線體', '高基氏體'], answer: 0 },
      // 填充題範例：
      { type: 'fill', id: 'Q2', text: '細胞膜的主要成分為___。', answer: '磷脂雙層' }
    ]
  },
  {
    id: 'L002',
    title: '第二課：光合作用的光反應',
    topic: 'Ch.5 光合作用',
    description: '探討葉綠體的結構，以及光反應中 ATP 和 NADPH 的產生過程。',
    videoId: 'YOUTUBE_VIDEO_ID_HERE',
    dueDate: '2026-06-08',
    estimatedMin: 20,
    questions: [
      { type: 'mcq', id: 'Q1', text: '光反應發生的位置是？',
        options: ['基質', '類囊體膜', '線粒體嵴', '核糖體'], answer: 1 },
      { type: 'fill', id: 'Q2', text: '光合作用的方程式：6CO₂ + 6H₂O → ___ + 6O₂。', answer: 'C₆H₁₂O₆' }
    ]
  }
  */
];

/* ============================================================================
 * 【區塊 3】UTILITIES（工具函式）
 * ============================================================================ */
const {
  useState, useEffect, useMemo, useRef,
  useCallback, useContext, createContext, memo
} = React;
const MotionLib = window.Motion || { motion: { div: 'div', span: 'span' }, AnimatePresence: ({children}) => children };
const { motion, AnimatePresence } = MotionLib;

/* ── 日期工具 ── */
function getHKDateString(dateObj) {
  const base = dateObj || new Date();
  const utc  = base.getTime() + base.getTimezoneOffset() * 60000;
  const hk   = new Date(utc + 3600000 * 8);
  const y = hk.getFullYear();
  const m = String(hk.getMonth() + 1).padStart(2,'0');
  const d = String(hk.getDate()).padStart(2,'0');
  return `${y}-${m}-${d}`;
}

function formatDateDisplay(dateStr) {
  if (!dateStr) return '';
  const [y,m,d] = dateStr.split('-');
  return `${y}年${parseInt(m)}月${parseInt(d)}日`;
}

function isDueSoon(dateStr) {
  if (!dateStr) return false;
  const today = new Date(getHKDateString());
  const due   = new Date(dateStr);
  const diff  = Math.round((due - today) / (1000 * 60 * 60 * 24));
  return diff >= 0 && diff <= 3;
}

function isOverdue(dateStr) {
  if (!dateStr) return false;
  return getHKDateString() > dateStr;
}

/* ── 名稱工具 ── */
function shortenName(fullName) {
  if (!fullName) return '';
  return String(fullName)
    .replace(/^\s*[4-6][A-Z]\d+\s*/i, '')
    .replace(/\s*\([\d\-]+\)(\s*[A-Za-z0-9]+)?\s*$/, '')
    .trim();
}

function normalizeNameForMatch(name) {
  if (!name) return '';
  return shortenName(name).toLowerCase().trim().split(/\s+/).filter(Boolean).sort().join(' ');
}

const TEACHER_NORMALIZED_SET = new Set(CONFIG.TEACHER_NAMES.map(normalizeNameForMatch));

function isTeacher(name) {
  if (!name || name === '訪客 (未登入)') return false;
  const n = normalizeNameForMatch(name);
  return !!n && TEACHER_NORMALIZED_SET.has(n);
}

/* ── JWT 解碼 ── */
function decodeJwtResponse(token) {
  const base64 = token.split('.')[1].replace(/-/g,'+').replace(/_/,'/');
  return JSON.parse(decodeURIComponent(
    atob(base64).split('').map(c => '%' + ('00'+c.charCodeAt(0).toString(16)).slice(-2)).join('')
  ));
}

/* ── YouTube IFrame API 載入 ── */
function loadYouTubeAPI() {
  return new Promise(resolve => {
    if (window.YT && window.YT.Player) { resolve(window.YT); return; }
    const prev = window.onYouTubeIframeAPIReady;
    window.onYouTubeIframeAPIReady = () => {
      if (prev) prev();
      resolve(window.YT);
    };
    if (!document.querySelector('script[src*="youtube.com/iframe_api"]')) {
      const s = document.createElement('script');
      s.src = 'https://www.youtube.com/iframe_api';
      document.head.appendChild(s);
    }
  });
}

/* ── 進度百分比格式化 ── */
function fmtPct(pct) { return `${Math.round(pct || 0)}%`; }

function watchPctColor(pct) {
  if (!pct || pct < 30)  return 'text-red-500 dark:text-red-400';
  if (pct < CONFIG.VIDEO_COMPLETE_THRESHOLD) return 'text-yellow-500 dark:text-yellow-400';
  return 'text-green-500 dark:text-green-400';
}

function watchPctBg(pct) {
  if (!pct || pct < 30)  return 'bg-red-500';
  if (pct < CONFIG.VIDEO_COMPLETE_THRESHOLD) return 'bg-yellow-500';
  return 'bg-green-500';
}

/* ── localStorage 進度存取 ── */
function loadLocalProgress(lessonId, studentName) {
  if (!lessonId || !studentName || studentName === '訪客 (未登入)') return null;
  try {
    const key = CONFIG.STORAGE.progress + lessonId + '_' + studentName;
    const raw = localStorage.getItem(key);
    return raw ? JSON.parse(raw) : null;
  } catch { return null; }
}

function saveLocalProgress(lessonId, studentName, data) {
  if (!lessonId || !studentName || studentName === '訪客 (未登入)') return;
  try {
    const key = CONFIG.STORAGE.progress + lessonId + '_' + studentName;
    localStorage.setItem(key, JSON.stringify({ ...data, savedAt: new Date().toISOString() }));
  } catch { /* ignore quota errors */ }
}

/* ============================================================================
 * 【區塊 4】TOAST SYSTEM（與原版完全相同）
 * ============================================================================ */
const TOAST_STYLE = {
  info:    { bg:'bg-indigo-500', border:'border-indigo-600', icon:'fa-circle-info' },
  success: { bg:'bg-green-500',  border:'border-green-600',  icon:'fa-circle-check' },
  warning: { bg:'bg-yellow-500', border:'border-yellow-600', icon:'fa-triangle-exclamation' },
  error:   { bg:'bg-red-500',    border:'border-red-600',    icon:'fa-circle-xmark' }
};

const ToastContext = createContext(null);

function ToastProvider({ children }) {
  const [toasts, setToasts] = useState([]);
  const addToast = useCallback((message, type = 'info', duration = 3000) => {
    const id = Date.now() + Math.random();
    setToasts(prev => [...prev.slice(-4), { id, message, type, duration }]);
    if (duration > 0) setTimeout(() => setToasts(prev => prev.filter(t => t.id !== id)), duration);
  }, []);
  return (
    <ToastContext.Provider value={addToast}>
      {children}
      <div className="fixed top-16 right-4 z-[9999] flex flex-col gap-2 pointer-events-none" style={{ maxWidth: '320px' }}>
        <AnimatePresence>
          {toasts.map(t => {
            const s = TOAST_STYLE[t.type] || TOAST_STYLE.info;
            return (
              <motion.div key={t.id}
                initial={{ opacity:0, x:60, scale:0.9 }}
                animate={{ opacity:1, x:0,  scale:1 }}
                exit={{   opacity:0, x:60,  scale:0.9 }}
                className={`${s.bg} ${s.border} border-l-4 text-white px-4 py-3 rounded-xl shadow-2xl pointer-events-auto flex items-center gap-2 text-sm`}>
                <i className={`fas ${s.icon} flex-shrink-0`}></i>
                <span>{t.message}</span>
              </motion.div>
            );
          })}
        </AnimatePresence>
      </div>
    </ToastContext.Provider>
  );
}

function useToast() { return useContext(ToastContext); }

/* ============================================================================
 * 【區塊 5】GOOGLE SIGN-IN HOOK
 * ============================================================================ */
function useGoogleSignIn(userName, setUserName) {
  const attemptRef = useRef(0);
  useEffect(() => {
    if (userName) { document.body.classList.add('logged-in'); return; }
    document.body.classList.remove('logged-in');
    const maxAttempts = 60;
    let timer = null;
    function tryRender() {
      attemptRef.current++;
      if (!window.google || !window.google.accounts || !window.google.accounts.id) {
        if (attemptRef.current < maxAttempts) timer = setTimeout(tryRender, 300);
        return;
      }
      const el = document.getElementById('googleSignInDiv');
      if (!el) { if (attemptRef.current < maxAttempts) timer = setTimeout(tryRender, 300); return; }
      try {
        window.google.accounts.id.initialize({
          client_id: CONFIG.GOOGLE_CLIENT_ID,
          callback: (response) => {
            try {
              const payload = decodeJwtResponse(response.credential);
              const email   = payload.email || '';
              const name    = payload.name  || email;
              if (!CONFIG.ALLOWED_EMAIL_DOMAIN || email.endsWith(CONFIG.ALLOWED_EMAIL_DOMAIN)) {
                setUserName(name);
                localStorage.setItem(CONFIG.STORAGE.username, name);
              } else {
                alert(`請使用學校電郵 (${CONFIG.ALLOWED_EMAIL_DOMAIN}) 登入`);
              }
            } catch { alert('登入失敗，請重試'); }
          }
        });
        window.google.accounts.id.renderButton(el, { theme:'outline', size:'large', width: 300 });
      } catch { /* ignore */ }
    }
    timer = setTimeout(tryRender, 300);
    return () => { if (timer) clearTimeout(timer); };
  }, [userName, setUserName]);
}

/* ============================================================================
 * 【區塊 6】DATA HOOK — 進度資料（雲端 + 本機同步）
 * ============================================================================
 *
 * useProgressData：負責
 *   1. 從 Google Apps Script 讀取所有學生進度（老師用）
 *   2. 將本機進度上傳至雲端
 *
 * ⚠️ 目前雲端 URL 尚未設定，所有操作只存 localStorage。
 *    設定 CONFIG.GOOGLE_SCRIPT_URL 後，補充下方 submitProgress() 即可接通雲端。
 * ============================================================================ */
function useProgressData(userName) {
  const [allProgress, setAllProgress] = useState(null);   // { [lessonId]: { [studentName]: progressObj } }
  const [loading, setLoading]         = useState(false);
  const [error, setError]             = useState(null);

  /* 載入雲端進度（老師用，或自己的進度） */
  const fetchProgress = useCallback(async () => {
    if (!userName || userName === '訪客 (未登入)') return;
    setLoading(true); setError(null);

    // TODO: 接通 Google Apps Script 後，將以下 mock 替換為真實 API 呼叫：
    // const res  = await fetch(`${CONFIG.GOOGLE_SCRIPT_URL}?action=getProgress`);
    // const data = await res.json();
    // setAllProgress(data.progress || {});

    /* 暫時從 localStorage 讀取所有進度 */
    try {
      const result = {};
      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (!k || !k.startsWith(CONFIG.STORAGE.progress)) continue;
        // key 格式：fc_progress_{lessonId}_{studentName}
        const rest   = k.slice(CONFIG.STORAGE.progress.length);
        const sepIdx = rest.indexOf('_');
        if (sepIdx < 0) continue;
        const lessonId    = rest.slice(0, sepIdx);
        const studentName = rest.slice(sepIdx + 1);
        try {
          const val = JSON.parse(localStorage.getItem(k));
          if (!result[lessonId]) result[lessonId] = {};
          result[lessonId][studentName] = val;
        } catch { /* ignore corrupt entries */ }
      }
      setAllProgress(result);
    } catch (e) { setError(e.message); }
    setLoading(false);
  }, [userName]);

  /* 儲存單次課題進度 */
  const submitProgress = useCallback(async (lessonId, progressObj) => {
    if (!userName || userName === '訪客 (未登入)') return;
    saveLocalProgress(lessonId, userName, progressObj);

    // TODO: 上傳至 Google Apps Script：
    // await fetch(CONFIG.GOOGLE_SCRIPT_URL, {
    //   method: 'POST',
    //   body: JSON.stringify({ action:'saveProgress', lessonId, student: userName, ...progressObj })
    // });

    /* 更新本地 allProgress 快照 */
    setAllProgress(prev => {
      const next = { ...(prev || {}) };
      if (!next[lessonId]) next[lessonId] = {};
      next[lessonId][userName] = progressObj;
      return next;
    });
  }, [userName]);

  useEffect(() => { fetchProgress(); }, [fetchProgress]);

  /* 取得某課題某學生的進度 */
  const getProgress = useCallback((lessonId, name = userName) => {
    if (allProgress && allProgress[lessonId] && allProgress[lessonId][name]) {
      return allProgress[lessonId][name];
    }
    return loadLocalProgress(lessonId, name || userName);
  }, [allProgress, userName]);

  return { allProgress, loading, error, submitProgress, getProgress, refetch: fetchProgress };
}

/* ============================================================================
 * 【區塊 7】SHARED COMPONENTS（共用元件）
 * ============================================================================ */

/* ── 圓形進度環 ── */
const ProgressRing = memo(function ProgressRing({ pct = 0, size = 48, strokeWidth = 4, label = '', className = '' }) {
  const r   = (size - strokeWidth * 2) / 2;
  const C   = 2 * Math.PI * r;
  const offset = C - (pct / 100) * C;
  const color = pct >= CONFIG.VIDEO_COMPLETE_THRESHOLD ? '#22c55e'
              : pct >= 30 ? '#eab308' : '#ef4444';
  return (
    <div className={`relative inline-flex items-center justify-center ${className}`} style={{ width: size, height: size }}>
      <svg width={size} height={size}>
        <circle cx={size/2} cy={size/2} r={r} fill="none"
          stroke="#e5e7eb" strokeWidth={strokeWidth} />
        <circle cx={size/2} cy={size/2} r={r} fill="none"
          stroke={color} strokeWidth={strokeWidth} strokeLinecap="round"
          strokeDasharray={C} strokeDashoffset={offset}
          className="progress-ring-circle" />
      </svg>
      <span className="absolute text-[10px] font-bold" style={{ color }}>
        {label || `${Math.round(pct)}%`}
      </span>
    </div>
  );
});

/* ── 課題狀態徽章 ── */
function LessonStatusBadge({ status }) {
  const map = {
    not_started: { label:'未開始', cls:'bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400', icon:'fa-circle' },
    watching:    { label:'觀看中', cls:'bg-blue-100 text-blue-600 dark:bg-blue-900/50 dark:text-blue-300', icon:'fa-play-circle' },
    answering:   { label:'作答中', cls:'bg-purple-100 text-purple-600 dark:bg-purple-900/50 dark:text-purple-300', icon:'fa-pen-to-square' },
    completed:   { label:'已完成', cls:'bg-green-100 text-green-700 dark:bg-green-900/50 dark:text-green-300', icon:'fa-circle-check' },
    overdue:     { label:'已逾期', cls:'bg-red-100 text-red-600 dark:bg-red-900/50 dark:text-red-300', icon:'fa-clock' },
  };
  const s = map[status] || map.not_started;
  return (
    <span className={`inline-flex items-center gap-1 text-xs font-bold px-2 py-0.5 rounded-full ${s.cls}`}>
      <i className={`fas ${s.icon} text-[10px]`}></i>
      {s.label}
    </span>
  );
}

/* ── 課題卡片（學生主頁使用） ── */
function LessonCard({ lesson, progress, onClick }) {
  const watchPct     = progress?.watchPct     || 0;
  const isCompleted  = !!progress?.completedAt;
  const questionsAnswered = progress?.answers ? Object.keys(progress.answers).length : 0;
  const totalQ = lesson.questions?.length || 0;

  let status = 'not_started';
  if (isCompleted) status = 'completed';
  else if (questionsAnswered > 0) status = 'answering';
  else if (watchPct > 0) status = 'watching';
  else if (lesson.dueDate && isOverdue(lesson.dueDate)) status = 'overdue';

  return (
    <motion.div
      whileHover={{ scale: 1.015 }}
      whileTap={{ scale: 0.985 }}
      onClick={onClick}
      className="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-4 shadow-sm hover:shadow-md transition-all cursor-pointer relative overflow-hidden"
    >
      {/* 左側色條 */}
      <div className={`absolute left-0 top-0 bottom-0 w-1 rounded-l-2xl ${
        isCompleted ? 'bg-green-500' : watchPct > 0 ? 'bg-blue-500' : 'bg-gray-200 dark:bg-gray-600'
      }`} />

      <div className="pl-3 flex items-start justify-between gap-3">
        <div className="flex-1 min-w-0">
