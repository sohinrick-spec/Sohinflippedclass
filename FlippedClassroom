                    </p>
                  </div>
                </div>
              )}
            </div>

            {/* 影片觀看進度條 */}
            <div className="mt-2 flex items-center gap-2">
              <div className="flex-1 h-2 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden">
                <div className={`h-full rounded-full transition-all duration-700 ${watchPctBg(maxWatchPct)}`}
                     style={{ width: fmtPct(maxWatchPct) }} />
              </div>
