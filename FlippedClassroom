                </h3>

                {/* ──────────────────────────────────────────────────
                 * TODO: 以下為題目渲染範例
                 * 實際課題資料填入後，此處將根據 question.type 渲染：
                 *   'mcq'  → 選擇題（4 選項按鈕）
                 *   'fill' → 填充題（文字輸入框）
                 * ────────────────────────────────────────────────── */}
                {lesson.questions.map((q, idx) => (
                  <QuestionItem
                    key={q.id}
                    question={q}
                    index={idx}
                    answer={answers[q.id]}
                    onAnswer={(val) => setAnswer(q.id, val)}
                    disabled={!!completedAt}
                  />
                ))}

                {/* 提交按鈕 */}
                {!completedAt && (
                  <button onClick={handleSubmit}
                    disabled={!allAnswered || submitLoading}
                    className={`w-full py-3 px-6 rounded-xl font-bold shadow-lg transition-all flex items-center justify-center gap-2 mt-2 ${
                      allAnswered
                        ? 'bg-gradient-to-r from-green-500 to-emerald-500 hover:from-green-600 hover:to-emerald-600 text-white hover:scale-[1.02]'
                        : 'bg-gray-200 dark:bg-gray-700 text-gray-400 dark:text-gray-500 cursor-not-allowed'
                    }`}>
                    {submitLoading
                      ? <><i className="fas fa-spinner fa-spin"></i>儲存中...</>
                      : allAnswered
                        ? <><i className="fas fa-paper-plane"></i>提交答案</>
                        : <><i className="fas fa-pen"></i>請完成所有題目（{answered}/{totalQ}）</>}
                  </button>
                )}

                {completedAt && (
                  <div className="p-4 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 rounded-xl text-center">
                    <i className="fas fa-trophy text-3xl text-yellow-500 mb-2"></i>
                    <p className="font-bold text-green-700 dark:text-green-300">課題已完成！</p>
                    <p className="text-xs text-green-600 dark:text-green-400 mt-1">
                      完成時間：{new Date(completedAt).toLocaleString('zh-HK')}
                    </p>
                  </div>
                )}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

/* ── 單道題目渲染元件 ── */
function QuestionItem({ question, index, answer, onAnswer, disabled }) {
  return (
    <div className="bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-xl p-4 shadow-sm">
      <p className="text-sm font-bold text-gray-700 dark:text-gray-200 mb-3">
        <span className="inline-flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 text-xs font-bold mr-2 flex-shrink-0">
          {index + 1}
        </span>
        {question.text}
      </p>

      {question.type === 'mcq' && (
        <div className="grid grid-cols-1 gap-2">
          {question.options.map((opt, oi) => {
            const selected = answer === String(oi);
            const isCorrect = disabled && oi === question.answer;
            const isWrong   = disabled && selected && oi !== question.answer;
            return (
              <button key={oi} onClick={() => !disabled && onAnswer(String(oi))}
                className={`text-left px-4 py-2.5 rounded-lg border-2 text-sm transition-all font-medium ${
                  disabled
                    ? isCorrect ? 'border-green-400 bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300'
                      : isWrong  ? 'border-red-400 bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400'
                      : 'border-gray-200 dark:border-gray-600 text-gray-500 dark:text-gray-400 opacity-60'
                    : selected
                      ? 'border-indigo-500 bg-indigo-50 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300 shadow'
                      : 'border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-200 hover:border-indigo-300 dark:hover:border-indigo-600 hover:bg-indigo-50/50 dark:hover:bg-indigo-900/20'
                }`}>
                <span className="font-bold mr-2">{['A','B','C','D','E'][oi]}.</span>
                {opt}
                {disabled && isCorrect && <i className="fas fa-check ml-2 text-green-500"></i>}
                {disabled && isWrong   && <i className="fas fa-times ml-2 text-red-500"></i>}
              </button>
            );
          })}
        </div>
      )}

      {question.type === 'fill' && (
        <div>
          <input
            type="text"
            value={answer || ''}
            onChange={e => !disabled && onAnswer(e.target.value)}
            disabled={disabled}
            placeholder="請在此輸入答案..."
            className={`w-full px-4 py-2.5 border-2 rounded-lg text-sm focus:outline-none transition-colors ${
              disabled
                ? 'border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-600 dark:text-gray-300 cursor-default'
                : 'border-gray-200 dark:border-gray-600 focus:border-indigo-400 dark:focus:border-indigo-500 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200'
            }`}
          />
          {disabled && answer && (
            <div className="mt-1.5 text-xs text-green-600 dark:text-green-400">
              <i className="fas fa-check-circle mr-1"></i>
              參考答案：{question.answer}
            </div>
          )}
        </div>
      )}
    </div>
  );
}

/* ============================================================================
 * 【區塊 10】STUDENT STATS SCREEN（學生個人學習記錄）
 * ============================================================================ */
function StudentStatsScreen({ userName, lessons, getProgress, onBack }) {
  const stats = useMemo(() => {
    return lessons.map(l => {
      const p = getProgress(l.id);
      return {
        lesson: l,
        watchPct:   p?.watchPct   || 0,
        answered:   p?.answers ? Object.keys(p.answers).length : 0,
        totalQ:     l.questions?.length || 0,
        completedAt: p?.completedAt || null,
        startedAt:   p?.startedAt  || null,
      };
    });
  }, [lessons, getProgress]);

  const completed  = stats.filter(s => s.completedAt).length;
  const inProgress = stats.filter(s => !s.completedAt && s.watchPct > 0).length;
  const avgWatch   = stats.length > 0
    ? Math.round(stats.reduce((a,s) => a + s.watchPct, 0) / stats.length)
    : 0;

  return (
    <div className="w-full max-w-lg">
      <div className="glass-panel p-4 md:p-6 rounded-2xl shadow-xl max-h-[92vh] overflow-y-auto custom-scrollbar">
        <div className="flex items-center gap-3 mb-5">
          <button onClick={onBack}
            className="w-9 h-9 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
            <i className="fas fa-arrow-left"></i>
          </button>
          <h2 className="text-xl font-bold text-gray-800 dark:text-gray-100">我的學習記錄</h2>
        </div>

        {/* KPI 卡 */}
        <div className="grid grid-cols-3 gap-3 mb-5">
          {[
            { icon:'✅', label:'已完成', value: completed,  color:'from-green-500 to-emerald-500' },
            { icon:'▶️', label:'進行中', value: inProgress, color:'from-blue-500 to-cyan-500' },
            { icon:'📊', label:'平均觀看', value: `${avgWatch}%`, color:'from-indigo-500 to-purple-500' },
          ].map((k,i) => (
            <div key={i} className="bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-xl p-3 text-center">
              <div className="text-xl mb-1">{k.icon}</div>
              <div className={`text-xl font-bold bg-gradient-to-r ${k.color} bg-clip-text text-transparent`}>{k.value}</div>
              <div className="text-xs text-gray-400 dark:text-gray-500">{k.label}</div>
            </div>
          ))}
        </div>

        {/* 課題明細 */}
        <div className="space-y-2">
          {stats.map(s => (
            <div key={s.lesson.id}
              className="flex items-center gap-3 bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-xl p-3">
              <ProgressRing pct={s.watchPct} size={44} strokeWidth={4} />
              <div className="flex-1 min-w-0">
                <p className="text-sm font-bold text-gray-700 dark:text-gray-200 truncate">{s.lesson.title}</p>
                <div className="flex items-center gap-2 text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                  <span>觀看 {fmtPct(s.watchPct)}</span>
                  {s.totalQ > 0 && <span>· 題目 {s.answered}/{s.totalQ}</span>}
                  {s.completedAt && <span className="text-green-500 dark:text-green-400 font-bold">· 已完成</span>}
                </div>
              </div>
              <LessonStatusBadge status={
                s.completedAt ? 'completed'
                : s.answered > 0 ? 'answering'
                : s.watchPct > 0 ? 'watching'
                : 'not_started'
              } />
            </div>
          ))}
        </div>

        {stats.length === 0 && (
          <EmptyState icon="📚" title="尚無學習記錄" subtitle="完成課題後這裡將顯示你的進度統計" />
        )}
      </div>
    </div>
  );
}

/* ============================================================================
 * 【區塊 11】TEACHER DASHBOARD SCREEN（教師儀表板）
 * ============================================================================ */
function TeacherDashboardScreen({ lessons, allProgress, onBack, onViewLessonReport, onRefresh, loading }) {
  /* 計算每課題的統計 */
  const lessonStats = useMemo(() => {
    return lessons.map(lesson => {
      const progressMap = allProgress?.[lesson.id] || {};
      const students    = Object.entries(progressMap);
      const started     = students.length;
      const completed   = students.filter(([,p]) => p.completedAt).length;
      const avgWatch    = started > 0
        ? Math.round(students.reduce((a,[,p]) => a + (p.watchPct||0), 0) / started)
        : 0;
      return { lesson, started, completed, avgWatch, progressMap };
    });
  }, [lessons, allProgress]);

  const totalStudents   = useMemo(() => {
    const names = new Set();
    Object.values(allProgress || {}).forEach(lp =>
      Object.keys(lp).forEach(n => names.add(n))
    );
    return names.size;
  }, [allProgress]);

  const totalCompleted  = lessonStats.reduce((a,s) => a + s.completed, 0);

  return (
    <div className="w-full max-w-3xl">
      <div className="glass-panel p-4 md:p-6 rounded-2xl shadow-xl max-h-[92vh] overflow-y-auto custom-scrollbar">

        {/* ── 標頭 ── */}
        <div className="flex items-center gap-3 mb-5">
          <button onClick={onBack}
            className="w-9 h-9 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
            <i className="fas fa-arrow-left"></i>
          </button>
          <div className="flex-1">
            <h2 className="text-xl font-bold text-gray-800 dark:text-gray-100">
              <i className="fas fa-chalkboard-teacher text-amber-500 mr-2"></i>教師儀表板
            </h2>
            <p className="text-xs text-gray-400 dark:text-gray-500">查看全班的影片觀看進度與答題情況</p>
          </div>
          <button onClick={onRefresh}
            className="w-9 h-9 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-gray-500 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
            title="重新整理">
            <i className={`fas fa-rotate-right ${loading ? 'fa-spin' : ''}`}></i>
          </button>
        </div>

        {/* ── KPI 列 ── */}
        <div className="grid grid-cols-3 gap-3 mb-5">
          {[
            { icon:'📹', label:'課題總數',     value: lessons.length,  color:'from-indigo-500 to-purple-500' },
            { icon:'👥', label:'參與學生',     value: totalStudents,   color:'from-blue-500 to-cyan-500' },
            { icon:'✅', label:'完成人次',     value: totalCompleted,  color:'from-green-500 to-emerald-500' },
          ].map((k,i) => (
            <div key={i} className="bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-xl p-3 text-center">
              <div className="text-xl mb-1">{k.icon}</div>
              <div className={`text-2xl font-bold bg-gradient-to-r ${k.color} bg-clip-text text-transparent`}>{k.value}</div>
              <div className="text-xs text-gray-400 dark:text-gray-500">{k.label}</div>
            </div>
          ))}
        </div>

        {/* ── 課題列表 ── */}
        {lessons.length === 0 ? (
          <EmptyState icon="📹" title="尚未設定任何課題" subtitle="在 LESSONS 陣列中填入課題後，這裡將顯示班級進度。" />
        ) : (
          <div className="space-y-3">
            <h3 className="text-sm font-bold text-gray-600 dark:text-gray-300 flex items-center gap-2">
              <i className="fas fa-list-check text-indigo-500"></i>各課題完成情況
            </h3>
            {lessonStats.map(s => (
              <button key={s.lesson.id}
                onClick={() => onViewLessonReport(s.lesson)}
                className="w-full text-left bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-xl p-4 hover:shadow-md hover:border-indigo-200 dark:hover:border-indigo-700 transition-all hover:scale-[1.01]">
                <div className="flex items-start gap-3">
                  <div className="flex-1 min-w-0">
                    <div className="flex items-center gap-2 flex-wrap mb-1">
                      <span className="text-xs bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-300 px-2 py-0.5 rounded-full font-bold">
                        {s.lesson.topic}
                      </span>
                      {s.lesson.dueDate && (
                        <span className={`text-xs px-2 py-0.5 rounded-full font-bold ${
                          isOverdue(s.lesson.dueDate)
                            ? 'bg-red-100 dark:bg-red-900/50 text-red-600 dark:text-red-300'
                            : 'bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400'
                        }`}>
                          截止 {s.lesson.dueDate}
                        </span>
                      )}
                    </div>
                    <p className="font-bold text-gray-800 dark:text-gray-100 truncate">{s.lesson.title}</p>

                    {/* 完成率進度條 */}
                    <div className="mt-2 flex items-center gap-2">
                      <div className="flex-1 h-2 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden">
                        {s.started > 0 && (
                          <div className="h-full bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full transition-all duration-700"
                               style={{ width: `${(s.completed / Math.max(s.started,1)) * 100}%` }} />
                        )}
                      </div>
                      <span className="text-xs text-gray-500 dark:text-gray-400 flex-shrink-0">
                        {s.started > 0 ? `${s.completed}/${s.started} 人完成` : '尚無人觀看'}
                      </span>
                    </div>

                    {/* 平均觀看 */}
                    {s.started > 0 && (
                      <div className="mt-1 text-xs text-gray-400 dark:text-gray-500">
                        平均觀看 <span className={`font-bold ${watchPctColor(s.avgWatch)}`}>{fmtPct(s.avgWatch)}</span>
                        ·  {s.started} 人已開始
                      </div>
                    )}
                  </div>
                  <i className="fas fa-chevron-right text-gray-300 dark:text-gray-600 mt-1 flex-shrink-0"></i>
                </div>
              </button>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}

