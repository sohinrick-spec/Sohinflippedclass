          <div className="flex items-center gap-2 mb-1 flex-wrap">
            <span className="text-xs bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-300 px-2 py-0.5 rounded-full font-bold">
              {lesson.topic}
            </span>
            <LessonStatusBadge status={status} />
            {lesson.dueDate && isDueSoon(lesson.dueDate) && !isCompleted && (
              <span className="text-xs bg-amber-100 dark:bg-amber-900/50 text-amber-700 dark:text-amber-300 px-2 py-0.5 rounded-full font-bold animate-pulse">
                <i className="fas fa-clock mr-1"></i>即將截止
              </span>
            )}
            {lesson.dueDate && isOverdue(lesson.dueDate) && !isCompleted && (
              <span className="text-xs bg-red-100 dark:bg-red-900/50 text-red-600 dark:text-red-300 px-2 py-0.5 rounded-full font-bold">
                <i className="fas fa-triangle-exclamation mr-1"></i>已逾期
              </span>
            )}
          </div>

          {/* 標題 */}
          <h3 className="font-bold text-gray-800 dark:text-gray-100 text-base leading-snug truncate">{lesson.title}</h3>

          {/* 描述 */}
          {lesson.description && (
            <p className="text-xs text-gray-500 dark:text-gray-400 mt-1 line-clamp-2">{lesson.description}</p>
