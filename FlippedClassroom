                             style={{ width: fmtPct(s.watchPct) }} />
                      </div>
                      <span className={`text-xs font-bold flex-shrink-0 w-9 text-right ${watchPctColor(s.watchPct)}`}>
                        {fmtPct(s.watchPct)}
                      </span>
                    </div>

                    {/* 答題 */}
                    <div className="text-center text-sm">
                      {totalQ > 0
                        ? <span className={answered >= totalQ ? 'text-green-500 dark:text-green-400 font-bold' : 'text-gray-500 dark:text-gray-400'}>
                            {answered}/{totalQ}
                          </span>
                        : <span className="text-gray-300 dark:text-gray-600">—</span>
                      }
                    </div>

                    {/* 狀態 */}
                    <div className="flex justify-center">
                      <LessonStatusBadge status={
                        s.completedAt ? 'completed'
                        : answered > 0 ? 'answering'
                        : s.watchPct > 0 ? 'watching'
                        : 'not_started'
                      } />
                    </div>

                    {/* 展開按鈕 */}
                    <button onClick={() => setExpandedStudent(isExpanded ? null : s.name)}
                      className="flex items-center justify-center text-gray-400 dark:text-gray-500 hover:text-indigo-500 dark:hover:text-indigo-400 transition-colors">
                      <i className={`fas fa-chevron-${isExpanded ? 'up' : 'down'} text-xs`}></i>
                    </button>
                  </div>

                  {/* 展開：顯示各題答案 */}
                  {isExpanded && totalQ > 0 && (
                    <div className="px-4 pb-3 pt-0 border-t border-gray-50 dark:border-gray-700/50">
                      <div className="mt-2 space-y-1.5">
                        {lesson.questions.map((q, qi) => {
                          const ans = s.answers?.[q.id];
                          const correct = q.type === 'mcq'
                            ? ans === String(q.answer)
                            : ans?.toLowerCase().trim() === q.answer?.toLowerCase().trim();
                          return (
                            <div key={q.id} className="flex items-start gap-2 text-xs">
                              <span className="font-bold text-gray-400 dark:text-gray-500 flex-shrink-0 w-6 text-right">Q{qi+1}</span>
                              <span className="text-gray-500 dark:text-gray-400 flex-1 min-w-0 truncate" title={q.text}>{q.text}</span>
                              {ans !== undefined ? (
                                <span className={`flex-shrink-0 px-2 py-0.5 rounded font-bold ${
                                  correct
                                    ? 'bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-300'
                                    : 'bg-red-100 dark:bg-red-900/50 text-red-600 dark:text-red-300'
                                }`}>
                                  {q.type === 'mcq' ? `選 ${['A','B','C','D'][parseInt(ans)]}` : ans}
                                  <i className={`fas ${correct ? 'fa-check' : 'fa-times'} ml-1`}></i>
                                </span>
                              ) : (
                                <span className="flex-shrink-0 px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500">
                                  未作答
                                </span>
                              )}
                            </div>
                          );
                        })}
                      </div>
                      {s.completedAt && (
                        <p className="text-[10px] text-gray-400 dark:text-gray-500 mt-2">
                          <i className="fas fa-clock mr-1"></i>
                          完成於 {new Date(s.completedAt).toLocaleString('zh-HK')}
                        </p>
                      )}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        )}
      </div>
    </div>
  );
}

/* ============================================================================
 * 【區塊 13】MAIN APP（主應用）
 * ============================================================================ */
function FlippedClassroomApp() {
  /* ── 持久化狀態 ── */
  const [userName, setUserName] = useState(() => localStorage.getItem(CONFIG.STORAGE.username) || '');
  const [isGuest, setIsGuest]   = useState(false);
  const [isDark, setIsDark]     = useState(() => localStorage.getItem(CONFIG.STORAGE.darkMode) === 'true');

  /* ── 頁面狀態機 ── */
  const [screen, setScreen] = useState('home');
  // 'home' | 'lesson' | 'student_stats' | 'teacher_dashboard' | 'teacher_lesson_report'

  /* ── 選中的課題（用於 lesson / teacher_lesson_report） ── */
  const [activelesson, setActiveLesson] = useState(null);

  /* ── 進度資料 ── */
  const { allProgress, loading, error, submitProgress, getProgress, refetch } =
    useProgressData(userName);

  /* ── 深色模式同步 ── */
  useEffect(() => {
    document.documentElement.classList.toggle('dark', isDark);
    localStorage.setItem(CONFIG.STORAGE.darkMode, isDark);
  }, [isDark]);

  /* ── 登出清理 ── */
  useEffect(() => {
    if (!userName) {
      localStorage.removeItem(CONFIG.STORAGE.username);
      setIsGuest(false);
      setScreen('home');
    } else {
      localStorage.setItem(CONFIG.STORAGE.username, userName);
    }
  }, [userName]);

  /* ── 頁面切換時更新 window.__APP_STATE__ ── */
  useEffect(() => {
    window.__APP_STATE__ = { gameState: screen };
    window.dispatchEvent(new Event('app-state-changed'));
  }, [screen]);

  /* ── 進入課題 ── */
  function handleOpenLesson(lesson) {
    setActiveLesson(lesson);
    setScreen('lesson');
  }

  /* ── 儲存課題進度 ── */
  async function handleSaveProgress(lessonId, progressObj) {
    await submitProgress(lessonId, progressObj);
  }

  const toast = useToast();
  if (error) toast(`進度資料載入錯誤: ${error}`, 'error');

  return (
    <div className={`min-h-screen transition-colors ${isDark ? 'dark bg-gray-900' : 'bg-gradient-to-br from-indigo-50 via-purple-50/30 to-blue-50'} flex items-start justify-center p-3 md:p-6 pt-4`}>

      {/* ── 深色模式切換按鈕（固定右上角） ── */}
      <button onClick={() => setIsDark(d => !d)}
        className="fixed top-4 right-4 z-[999] w-10 h-10 rounded-full bg-white dark:bg-gray-800 shadow-lg border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-yellow-400 flex items-center justify-center transition-all hover:scale-110">
        {isDark ? <i className="fas fa-sun text-lg"></i> : <i className="fas fa-moon text-lg"></i>}
      </button>

      {/* ── 主畫面 ── */}
      <AnimatePresence mode="wait">

        {screen === 'home' && (
          <motion.div key="home" initial={{opacity:0,y:20}} animate={{opacity:1,y:0}} exit={{opacity:0,y:-20}}
            className="w-full flex justify-center">
            <HomeScreen
              userName={userName} setUserName={setUserName}
              isGuest={isGuest}   setIsGuest={setIsGuest}
              lessons={LESSONS}
              getProgress={(lid) => getProgress(lid)}
              isDark={isDark}
              onOpenLesson={handleOpenLesson}
              onShowTeacherDashboard={() => setScreen('teacher_dashboard')}
              onShowStudentStats={() => setScreen('student_stats')}
            />
          </motion.div>
        )}

        {screen === 'lesson' && activelesson && (
          <motion.div key="lesson" initial={{opacity:0,x:50}} animate={{opacity:1,x:0}} exit={{opacity:0,x:-50}}
            className="w-full flex justify-center">
            <LessonPlayerScreen
              lesson={activelesson}
              userName={userName}
              initialProgress={getProgress(activelesson.id)}
              onSaveProgress={handleSaveProgress}
              onBack={() => setScreen('home')}
            />
          </motion.div>
        )}

        {screen === 'student_stats' && (
          <motion.div key="student_stats" initial={{opacity:0,x:50}} animate={{opacity:1,x:0}} exit={{opacity:0,x:-50}}
            className="w-full flex justify-center">
            <StudentStatsScreen
              userName={userName}
              lessons={LESSONS}
              getProgress={(lid) => getProgress(lid)}
              onBack={() => setScreen('home')}
            />
          </motion.div>
        )}

        {screen === 'teacher_dashboard' && (
          <motion.div key="tdash" initial={{opacity:0,x:50}} animate={{opacity:1,x:0}} exit={{opacity:0,x:-50}}
            className="w-full flex justify-center">
            {isTeacher(userName) ? (
              <TeacherDashboardScreen
                lessons={LESSONS}
                allProgress={allProgress}
                loading={loading}
                onBack={() => setScreen('home')}
                onRefresh={refetch}
                onViewLessonReport={(lesson) => { setActiveLesson(lesson); setScreen('teacher_lesson_report'); }}
              />
            ) : (
              <div className="glass-panel p-8 rounded-2xl shadow-xl text-center max-w-sm">
                <i className="fas fa-lock text-4xl text-red-500 mb-4"></i>
                <h2 className="text-xl font-bold text-gray-800 dark:text-gray-100 mb-2">權限不足</h2>
                <p className="text-gray-500 dark:text-gray-400 mb-4 text-sm">此頁面僅限教師使用。</p>
                <button onClick={() => setScreen('home')}
                  className="bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded-lg transition-colors">
                  返回主頁
                </button>
              </div>
            )}
          </motion.div>
        )}

        {screen === 'teacher_lesson_report' && activelesson && (
          <motion.div key="treport" initial={{opacity:0,x:50}} animate={{opacity:1,x:0}} exit={{opacity:0,x:-50}}
            className="w-full flex justify-center">
          {isTeacher(userName) ? (
            <TeacherLessonReportScreen
              lesson={activelesson}
              allProgress={allProgress}
              onBack={() => setScreen('teacher_dashboard')}
            />
          ) : (
            <div className="glass-panel p-8 rounded-2xl shadow-xl text-center max-w-sm">
              <i className="fas fa-lock text-4xl text-red-500 mb-4"></i>
              <button onClick={() => setScreen('home')} className="bg-gray-600 text-white px-6 py-2 rounded-lg">返回</button>
            </div>
          )}
          </motion.div>
        )}

      </AnimatePresence>
    </div>
  );
}

/* ============================================================================
 * 【區塊 14】ROOT RENDER
 * ============================================================================ */
function Root() {
  return (
    <ToastProvider>
      <FlippedClassroomApp />
    </ToastProvider>
  );
}

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<Root />);

</script>
</body>
</html>
